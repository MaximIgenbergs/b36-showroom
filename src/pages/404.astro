---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Seite nicht gefunden — Studentenvilla Bausewein">
  <section class="py-24 sm:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-serif text-5xl text-villa-dark mb-6">404</h1>
      <p class="font-sans text-lg text-villa-charcoal mb-8">
        Diese Seite existiert leider nicht.
      </p>
      <a
        href="/"
        class="bg-villa-gold text-white font-sans font-bold text-base px-8 py-4 hover:bg-villa-dark transition-all duration-300"
      >
        Zurück zur Startseite
      </a>
    </div>
  </section>
</BaseLayout>
