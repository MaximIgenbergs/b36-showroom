---
const { title = "Studentenvilla Bausewein" } = Astro.props;
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0"
    />

    <!-- SEO Meta -->
    <title>{title}</title>
    <meta
      name="description"
      content="Studentenvilla Bausewein — Premium-Studentenapartments in München-Obermenzing. Vollmöbliert, eigenes Bad mit Regendusche, Kitchenette, All-in-Miete. Jetzt bewerben."
    />
    <meta
      name="keywords"
      content="Studentenapartment München, Studentenvilla München, möbliertes Studentenzimmer München, Wohnen Obermenzing, Studentenwohnung München-West, All-inclusive Miete München"
    />
    <meta name="author" content="Studentenvilla Bausewein" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://villa-bausewein.de/" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph (Facebook, WhatsApp, iMessage Vorschau) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Premium-Studentenapartments in München-Obermenzing. Vollmöbliert, eigenes Bad, Kitchenette, All-in-Miete."
    />
    <meta property="og:url" content="https://villa-bausewein.de/" />
    <meta
      property="og:image"
      content="https://villa-bausewein.de/og-image.jpg"
    />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Studentenvilla bausewein" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta
      name="twitter:description"
      content="Premium-Studentenapartments in München-Obermenzing. Vollmöbliert, All-in-Miete."
    />
    <meta
      name="twitter:image"
      content="https://villa-bausewein.de/og-image.jpg"
    />

    <!-- Sprache -->
    <link rel="alternate" hreflang="de" href="https://villa-bausewein.de/" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
      <!-- slot = hier wird der Seiteninhalt eingesetzt -->
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
