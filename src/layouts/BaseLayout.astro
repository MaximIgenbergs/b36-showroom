---
const { title = "Studentenvilla Bausewein" } = Astro.props;
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0"
    />
    <meta
      name="description"
      content="Studentenvilla Bausewein — Premium-Studentenapartments in München-Obermenzing. Vollmöbliert, All-in-Miete, eigenes Bad."
    />
    <title>{title}</title>

    <!-- Open Graph für Social Media -->
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Premium-Studentenapartments in München-Obermenzing. Vollmöbliert, All-in-Miete, eigenes Bad."
    />
    <meta property="og:type" content="website" />

    <!-- Favicon (ersetze später durch echtes Logo) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
      <!-- slot = hier wird der Seiteninhalt eingesetzt -->
    </main>
    <Footer />
  </body>
</html>
