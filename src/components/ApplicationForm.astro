---
// Das Formular braucht einen Backend-Service für den Datei-Upload.
// Empfehlung: Formspree.io (kostenloser Tier: 50 Einreichungen/Monat, reicht für den Start)
// 1. Gehe auf https://formspree.io und erstelle einen Account
// 2. Erstelle ein neues Formular
// 3. Ersetze YOUR_FORM_ID unten durch deine Form-ID

const FORM_ENDPOINT = "https://formspree.io/f/xwvroqnp";
---

<form
  action={FORM_ENDPOINT}
  method="POST"
  enctype="multipart/form-data"
  class="max-w-2xl mx-auto space-y-6"
>
  <!-- Name -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label
        for="vorname"
        class="block font-sans text-sm font-bold text-villa-dark mb-1"
        >Vorname *</label
      >
      <input
        type="text"
        id="vorname"
        name="vorname"
        required
        class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
      />
    </div>
    <div>
      <label
        for="nachname"
        class="block font-sans text-sm font-bold text-villa-dark mb-1"
        >Nachname *</label
      >
      <input
        type="text"
        id="nachname"
        name="nachname"
        required
        class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
      />
    </div>
  </div>

  <!-- E-Mail -->
  <div>
    <label
      for="email"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >E-Mail-Adresse *</label
    >
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
    />
  </div>

  <!-- Telefon -->
  <div>
    <label
      for="telefon"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Telefonnummer</label
    >
    <input
      type="tel"
      id="telefon"
      name="telefon"
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
    />
  </div>

  <!-- Einzugstermin -->
  <div>
    <label
      for="einzug"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Gewünschter Einzugstermin *</label
    >
    <input
      type="date"
      id="einzug"
      name="einzug"
      required
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
    />
  </div>

  <!-- Hochschule -->
  <div>
    <label
      for="hochschule"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Hochschule / Studiengang *</label
    >
    <input
      type="text"
      id="hochschule"
      name="hochschule"
      required
      placeholder="z.B. LMU München, Informatik B.Sc."
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
    />
  </div>

  <!-- Apartment-Präferenz -->
  <div>
    <label
      for="praeferenz"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Apartment-Präferenz</label
    >
    <select
      id="praeferenz"
      name="praeferenz"
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors bg-white"
    >
      <option value="">Keine Präferenz</option>
      <option value="eg">Erdgeschoss (mit Terrasse)</option>
      <option value="og">Obergeschoss (mit Balkon)</option>
      <option value="dg">Dachgeschoss (mit Balkon)</option>
      <option value="doppel">Doppelapartment D3 (ca. 34 m²)</option>
    </select>
  </div>

  <!-- Immatrikulationsbescheinigung Upload -->
  <div>
    <label
      for="immatrikulation"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
    >
      Immatrikulationsbescheinigung (PDF/JPG) *
    </label>
    <input
      type="file"
      id="immatrikulation"
      name="immatrikulation"
      required
      accept=".pdf,.jpg,.jpeg,.png"
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors file:mr-4 file:py-1 file:px-3 file:border-0 file:text-sm file:font-bold file:bg-villa-gold file:text-white"
    />
    <p class="font-sans text-xs text-villa-charcoal/60 mt-1">
      Maximale Dateigröße: 10 MB
    </p>
  </div>

  <!-- Nachricht -->
  <div>
    <label
      for="nachricht"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Kurzes Anschreiben</label
    >
    <textarea
      id="nachricht"
      name="nachricht"
      rows="4"
      placeholder="Optional: Erzählen Sie uns kurz etwas über sich."
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors resize-y"
    ></textarea>
  </div>

  <!-- Checkboxen -->
  <div class="space-y-3">
    <label class="flex items-start gap-3">
      <input
        type="checkbox"
        name="datenschutz"
        required
        class="mt-1 accent-villa-gold"
      />
      <span class="font-sans text-xs text-villa-charcoal">
        Ich habe die <a href="/datenschutz" class="text-villa-gold underline"
          >Datenschutzerklärung</a
        > gelesen und bin mit der Verarbeitung meiner Daten einverstanden. *
      </span>
    </label>
    <label class="flex items-start gap-3">
      <input
        type="checkbox"
        name="makler-hinweis"
        required
        class="mt-1 accent-villa-gold"
      />
      <span class="font-sans text-xs text-villa-charcoal">
        Mir ist bekannt, dass die Vermietung über einen beauftragten Makler
        erfolgt und im Vermietungsfall die gesetzliche Maklerprovision durch
        mich zu tragen ist. *
      </span>
    </label>
  </div>

  <!-- Honeypot (Spam-Schutz, unsichtbar für Menschen) -->
  <input
    type="text"
    name="_gotcha"
    style="display:none"
    tabindex="-1"
    autocomplete="off"
  />

  <!-- Submit -->
  <button
    type="submit"
    class="w-full bg-villa-gold text-white font-sans font-bold text-base py-4 hover:bg-villa-dark transition-colors"
  >
    Bewerbung absenden
  </button>
</form>
