---

---

<form id="bewerbung-form" class="max-w-2xl mx-auto space-y-6">
  <!-- Name -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label
        for="vorname"
        class="block font-sans text-sm font-bold text-villa-dark mb-1"
        >Vorname *</label
      >
      <input
        type="text"
        id="vorname"
        name="vorname"
        required
        class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
      />
    </div>
    <div>
      <label
        for="nachname"
        class="block font-sans text-sm font-bold text-villa-dark mb-1"
        >Nachname *</label
      >
      <input
        type="text"
        id="nachname"
        name="nachname"
        required
        class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
      />
    </div>
  </div>

  <!-- E-Mail -->
  <div>
    <label
      for="email"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >E-Mail-Adresse *</label
    >
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
    />
  </div>

  <!-- Telefon -->
  <div>
    <label
      for="telefon"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Telefonnummer</label
    >
    <input
      type="tel"
      id="telefon"
      name="telefon"
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
    />
  </div>

  <!-- Einzugstermin -->
  <div>
    <label
      for="einzug"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Gewünschter Einzugstermin *</label
    >
    <input
      type="date"
      id="einzug"
      name="einzug"
      required
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
    />
  </div>

  <!-- Hochschule -->
  <div>
    <label
      for="hochschule"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Hochschule / Studiengang *</label
    >
    <input
      type="text"
      id="hochschule"
      name="hochschule"
      required
      placeholder="z.B. LMU München, Informatik B.Sc."
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors"
    />
  </div>

  <!-- Apartment-Präferenz -->
  <div>
    <label
      for="praeferenz"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Apartment-Präferenz</label
    >
    <select
      id="praeferenz"
      name="praeferenz"
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors bg-white"
    >
      <option value="">Keine Präferenz</option>
      <option value="eg">Erdgeschoss (mit Terrasse)</option>
      <option value="og">Obergeschoss (mit Balkon)</option>
      <option value="dg">Dachgeschoss (mit Balkon)</option>
      <option value="doppel">Doppelapartment D3 (ca. 34 m²)</option>
    </select>
  </div>

  <!-- Immatrikulationsbescheinigung Upload -->
  <div>
    <label
      for="immatrikulation"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
    >
      Immatrikulationsbescheinigung (PDF/JPG) *
    </label>
    <input
      type="file"
      id="immatrikulation"
      name="immatrikulation"
      required
      accept=".pdf,.jpg,.jpeg,.png"
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors file:mr-4 file:py-1 file:px-3 file:border-0 file:text-sm file:font-bold file:bg-villa-gold file:text-white"
    />
    <p class="font-sans text-xs text-villa-charcoal/60 mt-1">
      Maximale Dateigröße: 10 MB
    </p>
  </div>

  <!-- Nachricht -->
  <div>
    <label
      for="nachricht"
      class="block font-sans text-sm font-bold text-villa-dark mb-1"
      >Kurzes Anschreiben</label
    >
    <textarea
      id="nachricht"
      name="nachricht"
      rows="4"
      placeholder="Optional: Erzählen Sie uns kurz etwas über sich."
      class="w-full px-4 py-3 border border-villa-charcoal/20 font-sans text-sm focus:outline-none focus:border-villa-gold transition-colors resize-y"
    ></textarea>
  </div>

  <!-- Checkboxen -->
  <div class="space-y-3">
    <label class="flex items-start gap-3">
      <input
        type="checkbox"
        name="datenschutz"
        required
        class="mt-1 accent-villa-gold"
      />
      <span class="font-sans text-xs text-villa-charcoal">
        Ich habe die <a href="/datenschutz" class="text-villa-gold underline"
          >Datenschutzerklärung</a
        > gelesen und bin mit der Verarbeitung meiner Daten einverstanden. *
      </span>
    </label>
    <label class="flex items-start gap-3">
      <input
        type="checkbox"
        name="makler-hinweis"
        required
        class="mt-1 accent-villa-gold"
      />
      <span class="font-sans text-xs text-villa-charcoal">
        Mir ist bekannt, dass die Vermietung über einen beauftragten Makler
        erfolgt und im Vermietungsfall die gesetzliche Maklerprovision durch
        mich zu tragen ist. *
      </span>
    </label>
  </div>

  <!-- Honeypot -->
  <input
    type="text"
    name="_gotcha"
    style="display:none"
    tabindex="-1"
    autocomplete="off"
  />

  <!-- Status-Meldungen -->
  <div id="form-status" class="hidden font-sans text-sm text-center p-4"></div>

  <!-- Submit -->
  <button
    type="submit"
    id="submit-btn"
    class="w-full bg-villa-gold text-white font-sans font-bold text-base py-4 hover:bg-villa-dark transition-all duration-300"
  >
    Bewerbung absenden
  </button>
</form>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabaseUrl = "https://vykqptolkzzbpuxsagvp.supabase.co";
  const supabaseAnonKey =
    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ5a3FwdG9sa3p6YnB1eHNhZ3ZwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMzMDI5NjksImV4cCI6MjA4ODg3ODk2OX0.QQO-7-z6v7QZLTTpLBBt9jxz9EsXOhYIcOFq1gF05zk";
  const supabase = createClient(supabaseUrl, supabaseAnonKey);

  const form = document.getElementById("bewerbung-form");
  const status = document.getElementById("form-status");
  const submitBtn = document.getElementById("submit-btn");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Honeypot check
    const honeypot = form.querySelector('[name="_gotcha"]');
    if (honeypot && honeypot.value) return;

    // Disable button
    submitBtn.disabled = true;
    submitBtn.textContent = "Wird gesendet...";
    submitBtn.classList.add("opacity-50");

    try {
      // Datei hochladen
      let immatrikulationUrl = null;
      const fileInput = document.getElementById("immatrikulation");
      const file = fileInput?.files?.[0];

      if (file) {
        if (file.size > 10 * 1024 * 1024) {
          throw new Error("Datei ist größer als 10 MB.");
        }

        const timestamp = Date.now();
        const safeName = file.name.replace(/[^a-zA-Z0-9._-]/g, "_");
        const filePath = `${timestamp}_${safeName}`;

        const { data: uploadData, error: uploadError } = await supabase.storage
          .from("immatrikulation")
          .upload(filePath, file);

        if (uploadError) throw new Error("Datei-Upload fehlgeschlagen.");

        const { data: urlData } = supabase.storage
          .from("immatrikulation")
          .getPublicUrl(filePath);

        immatrikulationUrl = urlData.publicUrl;
      }

      // Formulardaten in Datenbank speichern
      const { error: dbError } = await supabase.from("bewerbungen").insert({
        vorname: form.vorname.value,
        nachname: form.nachname.value,
        email: form.email.value,
        telefon: form.telefon.value || null,
        einzug: form.einzug.value,
        hochschule: form.hochschule.value,
        praeferenz: form.praeferenz.value || null,
        nachricht: form.nachricht.value || null,
        immatrikulation_url: immatrikulationUrl,
      });

      if (dbError) throw new Error("Speichern fehlgeschlagen.");

      // Erfolg
      status.textContent =
        "Ihre Bewerbung wurde erfolgreich gesendet! Wir melden uns in Kürze bei Ihnen.";
      status.classList.remove("hidden", "bg-red-50", "text-red-700");
      status.classList.add("bg-green-50", "text-green-700");
      form.reset();
    } catch (err) {
      status.textContent =
        err.message ||
        "Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut.";
      status.classList.remove("hidden", "bg-green-50", "text-green-700");
      status.classList.add("bg-red-50", "text-red-700");
    }

    // Button zurücksetzen
    submitBtn.disabled = false;
    submitBtn.textContent = "Bewerbung absenden";
    submitBtn.classList.remove("opacity-50");
  });
</script>
