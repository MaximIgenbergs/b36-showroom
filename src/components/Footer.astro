---
const currentYear = new Date().getFullYear();
---

<footer class="bg-villa-dark text-white py-12 sm:py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Logo zentriert -->
    <div class="text-center mb-10">
      <img
        src="/images/logo-gold-transparent.svg"
        alt="Studentenvilla Bauseweinallee"
        class="h-10 mx-auto mb-4"
      />
      <p class="font-sans text-sm text-white/60">
        Bauseweinallee 36c · 81247 München-Obermenzing
      </p>
    </div>

    <!-- Links in einer Zeile -->
    <nav class="flex flex-wrap justify-center gap-x-8 gap-y-2 mb-10">
      <a
        href="/#villa"
        class="font-sans text-sm text-white/60 hover:text-villa-gold transition-colors"
        >Die Villa</a
      >
      <a
        href="/#apartments"
        class="font-sans text-sm text-white/60 hover:text-villa-gold transition-colors"
        >Apartments</a
      >
      <a
        href="/#ausstattung"
        class="font-sans text-sm text-white/60 hover:text-villa-gold transition-colors"
        >Ausstattung</a
      >
      <a
        href="/#lage"
        class="font-sans text-sm text-white/60 hover:text-villa-gold transition-colors"
        >Lage</a
      >
      <a
        href="/#miete"
        class="font-sans text-sm text-white/60 hover:text-villa-gold transition-colors"
        >Miete</a
      >
      <a
        href="/#bewerben"
        class="font-sans text-sm text-white/60 hover:text-villa-gold transition-colors"
        >Bewerben</a
      >
    </nav>

    <!-- Trennlinie -->
    <div class="border-t border-white/10 pt-8">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="font-sans text-xs text-white/40">
          &copy; {currentYear} VVG Bauseweinallee KG. Alle Rechte vorbehalten.
        </p>
        <div class="flex gap-6">
          <a
            href="/impressum"
            class="font-sans text-xs text-white/40 hover:text-villa-gold transition-colors"
            >Impressum</a
          >
          <a
            href="/datenschutz"
            class="font-sans text-xs text-white/40 hover:text-villa-gold transition-colors"
            >Datenschutz</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>
